{
  "name": "ai-search-snippet-workers",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "clean:wrangler": "node -e \"const fs=require('node:fs');['.wrangler/deploy','../../.wrangler/deploy'].forEach((path)=>{try{fs.rmSync(path,{recursive:true,force:true})}catch{}})\"",
    "dev": "astro dev",
    "dev:worker": "pnpm run clean:wrangler && pnpm run build && wrangler dev",
    "build": "pnpm --filter @cloudflare/ai-search-snippet run build && astro check && astro build",
    "preview": "pnpm run clean:wrangler && pnpm run build && wrangler dev",
    "preview:static": "astro preview",
    "typecheck": "pnpm --filter @cloudflare/ai-search-snippet run build && astro check",
    "deploy": "pnpm run build && wrangler deploy"
  },
  "dependencies": {
    "@cloudflare/ai-search-snippet": "workspace:*"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "astro": "^6.1.6",
    "typescript": "~5.8.3",
    "wrangler": "^4.58.0"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
